cmake_minimum_required(VERSION 3.10)
project(GeminiNcursesChat CXX)

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED True)
set(CMAKE_POSITION_INDEPENDENT_CODE ON) # Good practice for libraries, might help with some linking issues

# Path to nlohmann/json (adjust if different)
# Assuming json.hpp is directly in 'include/nlohmann'
# For subdirectories, CMake usually handles include paths if they have their own CMakeLists.txt
# remove this line if 'externals/json' handles its own include path correctly
# include_directories(include/nlohmann/) 
add_subdirectory(externals/json)
# find_package(json CONFIG REQUIRED) # This line is usually for installed packages, not subdirectories

# Add cpr as a subdirectory or find it
# If you downloaded cpr into an 'externals/cpr' folder
# remove this line if 'externals/cpr' handles its own include path correctly
# include_directories(include/cpr)
add_subdirectory(externals/cpr)
# find_package(cpr CONFIG REQUIRED) # This line is usually for installed packages, not subdirectories

# Find ncurses (CURSES for CMake)
find_package(Curses REQUIRED)

add_executable(gemini_ncurses_chat main.cpp)

target_link_libraries(gemini_ncurses_chat PRIVATE
    cpr::cpr # This links cpr and its curl dependency
    nlohmann_json::nlohmann_json # This links nlohmann/json
    ${CURSES_LIBRARIES} # Links ncurses
)

# Optional: Add compiler definitions for cpr if the macro conflict persists
# This should be handled in main.cpp, but can be a fallback here if needed
# target_compile_definitions(gemini_ncurses_chat PRIVATE CPR_LIBCURL_NO_CURL_EASY_HACKS)
